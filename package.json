{
  "name": "herb-lytics",
  "version": "1.1.17",
  "private": true,
  "type": "module",
  "description": "Herbal purchase value dashboard — Rust (Leptos CSR) frontend. Tailwind is compiled to CSS via the CLI; the app logic is WASM.",
  "scripts": {
    "build:css": "tailwindcss -i ./tailwind.css -o ./public/styles/main.css",
    "watch:css": "tailwindcss -i ./tailwind.css -o ./public/styles/main.css --watch",
    "dev": "make dev",
    "build": "make build"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2"
  }
}
